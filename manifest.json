{
    "manifest_version": 3,
    "name": "AI Writing Assistant",
    "version": "1.0.0",
    "description": "Grammar, style, and synonym suggestions powered by Google Gemini. Select text on any page to get instant AI-powered writing help.",
    "permissions": [
        "activeTab",
        "storage",
        "contextMenus"
    ],
    "host_permissions": [
        "https://generativelanguage.googleapis.com/*",
        "https://api.openai.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "selection-utils.js",
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "options_ui": {
        "page": "options.html",
        "open_in_tab": false
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}